# =============================================================================
# Openclaw Mail Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to version control.
#
# Account passwords should match the `password_env` field in
# config/accounts.yaml. Add one variable per account.
# =============================================================================

# ---------------------------------------------------------------------------
# Email Account Credentials (user + password per account)
# ---------------------------------------------------------------------------
# Each account in config/accounts.yaml references a user_env and password_env.
# Add one pair per account. Multiple accounts can share the same credentials.
#
# For Gmail: generate App Passwords at https://myaccount.google.com/apppasswords
# For DavMail/Exchange: use your Exchange password or app token.

# Work account
USER_WORK="user@company.com"
PASS_WORK="your_work_password"

# Personal account
USER_PERSONAL="user@gmail.com"
PASS_PERSONAL="your_gmail_app_password"

# Secondary account
USER_SECONDARY="secondary@gmail.com"
PASS_SECONDARY="your_secondary_app_password"

# ---------------------------------------------------------------------------
# DavMail Configuration (Exchange/Office365 IMAP bridge)
# ---------------------------------------------------------------------------
# Only needed if you have a DavMail/Exchange account.
# Use "host.docker.internal" instead of "localhost" when running in Docker.
DAVMAIL_HOST="localhost"
DAVMAIL_IMAP_PORT="1143"
DAVMAIL_SMTP_PORT="1025"
DAVMAIL_CALDAV_PORT="1080"

# ---------------------------------------------------------------------------
# Gmail IMAP
# ---------------------------------------------------------------------------
GMAIL_HOST="imap.gmail.com"
GMAIL_PORT="993"

# ---------------------------------------------------------------------------
# Calendar Sync (optional)
# ---------------------------------------------------------------------------
# CalDAV (for Exchange/DavMail accounts)
CALDAV_WORK_URL="http://localhost:1080/users/user@company.com/calendar"

# Google Calendar API (for Gmail accounts)
GOOGLE_CLIENT_SECRETS_FILE="config/client_secrets.json"
GOOGLE_TOKEN_FILE="config/token.json"

# ---------------------------------------------------------------------------
# Logging & Reports
# ---------------------------------------------------------------------------
LOG_DIR="logs"
REPORT_DIR="reports"
LOG_LEVEL="INFO"
