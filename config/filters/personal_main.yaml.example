# =============================================================================
# Personal Account — Filter Configuration (EXAMPLE)
# =============================================================================
# Copy to <account_id>.yaml and customize for your personal account.
# See spec/ARCHITECTURE.md for full pipeline documentation.
#
# Personal accounts typically have no address rules (Step 1) and rely on
# keyword rules (Step 2) for common services and AI scoring (Step 3) for nuance.
# =============================================================================

ai_score_threshold: 0.8
review_folder: "Review"

address_rules: []

# Step 2: Keyword-based rules — common personal services
keyword_rules:
  - pattern: "(newsletter|marketing|digest|noreply|promotions|linkedin|facebook)"
    folder: "Newsletters"
    confidence: 0.95
  - pattern: "(invoice|receipt|payment|bill|fatura|boleto)"
    folder: "Finance"
    confidence: 0.90
  - pattern: "(security|alert|verify|login|auth)"
    folder: "Security"
    confidence: 0.95
  - pattern: "(amazon|paypal|delivery|shop|tracking|dhl|ups)"
    folder: "Shopping"
    confidence: 0.85
  - pattern: "(flight|hotel|booking|airbnb|train|travel)"
    folder: "Travel"
    confidence: 0.85
  - pattern: "(doctor|pharmacy|prescription|medical|health)"
    folder: "Personal/Medical"
    confidence: 0.90
  - pattern: "(university|student|course|education)"
    folder: "Personal/Education"
    confidence: 0.85
  - pattern: "(phone|internet|electricity|water|gas|utility)"
    folder: "Utilities"
    confidence: 0.90
  - pattern: "(job|application|recruitment|candidature)"
    folder: "Applications"
    confidence: 0.85

# Step 3: Folder definitions for AI scoring
folder_definitions:
  Applications: "Job applications, recruitment processes"
  Archive: "Old emails, no longer actionable"
  Events: "Event tickets, concerts, cultural events"
  Finance: "Banking, invoices, payments, credit card statements"
  Food: "Food delivery orders, restaurant bookings"
  Newsletters: "Marketing emails, subscriptions"
  Personal: "General personal correspondence"
  Personal/Education: "University, courses, certifications"
  Personal/Medical: "Medical appointments, pharmacy, prescriptions, health"
  Security: "Security alerts, verification codes"
  Shopping: "Online orders, delivery tracking, e-commerce"
  Travel: "Flight bookings, hotel reservations, travel itineraries"
  Utilities: "Phone bills, internet, electricity, water"
